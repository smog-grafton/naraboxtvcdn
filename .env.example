APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CDN_APP_URL=http://127.0.0.1:8000
CDN_DEFAULT_IMPORT_MODE=queue
CDN_INGEST_SECRET=
PORTAL_FETCH_PROXY_URL=https://portal.naraboxtv.com/api/cdn/fetch-and-push
PORTAL_FETCH_PROXY_TOKEN=
CDN_PYTHON_WORKER_ENABLED=false
CDN_PYTHON_WORKER_QUEUE_URL=
CDN_PYTHON_WORKER_AUTH_TOKEN=
# Laravel worker (naraboxtvworker): when enabled, optimization is sent to the worker instead of local queue.
# Worker URL: e.g. http://wwwogwgw80cwo4g4skw8oggg.157.173.104.218.sslip.io or https://worker.naraboxtv.com
CDN_LARAVEL_WORKER_ENABLED=false
CDN_LARAVEL_WORKER_API_URL=
CDN_LARAVEL_WORKER_API_TOKEN=
CDN_FFMPEG_BINARY=/home/naraboxt/domains/cdn.naraboxtv.com/public_html/ffmpeg/ffmpeg
CDN_FFPROBE_BINARY=/home/naraboxt/domains/cdn.naraboxtv.com/public_html/ffmpeg/ffprobe
CDN_ENABLE_HLS=true
CDN_HLS_PROFILES=1080,720,480
MAX_UPLOAD_MB=2048
ALLOWED_VIDEO_EXTENSIONS=mp4,mkv,webm,avi,mov,m4v

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
